# API / workers — raiz do monorepo (cp .env.example .env)
API_PORT=3001
ENABLE_WORKERS=true
CORS_ORIGIN=http://localhost:3000
REDIS_URL=redis://localhost:6379
WA_SESSION_PATH=./sessions
PRIVACY_RETENTION_INTERVAL_HOURS=24
LOG_LEVEL=info

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
