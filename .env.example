ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_UNLIMITED=
