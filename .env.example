# Ports
API_PORT=3001

# Postgres (service: postgres)
POSTGRES_USER=zapflow
POSTGRES_PASSWORD=zapflow
POSTGRES_DB=zapflow

# Database / Redis
DATABASE_URL=postgresql://zapflow:zapflow@localhost:5432/zapflow
REDIS_URL=redis://localhost:6379

# API (Vercel: ENABLE_WORKERS=false)
ENABLE_WORKERS=true
CORS_ORIGIN=*
API_SECRET=change-me-in-production

# Produção Vercel
# API: https://zap-flow-api-peach.vercel.app
