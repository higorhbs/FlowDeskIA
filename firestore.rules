rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function emailVerified() {
      return signedIn() && (
        request.auth.token.email_verified == true ||
        request.auth.token.firebase.sign_in_provider == 'google.com'
      );
    }
    function signedInAndVerified() {
      return emailVerified();
    }
    function isOwner(tenantId) {
      return signedInAndVerified() && request.auth.uid == tenantId;
    }
    function businessOwned(businessId) {
      return signedInAndVerified() &&
        get(/databases/$(database)/documents/businesses/$(businessId)).data.tenantId == request.auth.uid;
    }

    function tenantProfileUpdateAllowed() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'name',
          'email',
          'onboardingCompletedAt',
          'lgpdAcceptedAt',
          'lgpdPolicyVersion',
          'cancellationFeedbackRating',
          'cancellationFeedbackText',
          'cancellationFeedbackAt',
          'updatedAt'
        ]);
    }

    function tenantCreateAllowed() {
      return request.resource.data.keys().hasOnly([
          'id',
          'name',
          'email',
          'plan',
          'planStatus',
          'trialEndsAt',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id == tenantId
        && request.resource.data.plan == 'STARTER'
        && request.resource.data.planStatus == 'TRIALING'
        && request.resource.data.id is string
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.trialEndsAt is string
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
    }

    match /tenants/{tenantId} {
      allow read: if isOwner(tenantId);
      allow create: if isOwner(tenantId) && tenantCreateAllowed();
      allow update: if isOwner(tenantId) && tenantProfileUpdateAllowed();
      allow delete: if false;
    }

    match /businesses/{businessId} {
      allow read: if signedInAndVerified() && resource.data.tenantId == request.auth.uid;
      allow create: if signedInAndVerified() && request.resource.data.tenantId == request.auth.uid;
      allow update, delete: if signedInAndVerified()
        && resource.data.tenantId == request.auth.uid
        && request.resource.data.tenantId == resource.data.tenantId;

      match /catalog/{itemId} {
        allow read, write: if businessOwned(businessId);
      }
      match /faqs/{faqId} {
        allow read, write: if businessOwned(businessId);
      }
      match /conversations/{convId} {
        allow read, write: if businessOwned(businessId);
        match /messages/{msgId} {
          allow read, write: if businessOwned(businessId);
        }
      }
      match /appointments/{aptId} {
        allow read, write: if businessOwned(businessId);
      }
      match /payments/{payId} {
        allow read: if businessOwned(businessId);
        allow write: if false;
      }
      match /scheduledStatuses/{statusId} {
        allow read, write: if businessOwned(businessId);
      }
      match /integrations/{docId} {
        allow read, write: if false;
      }
    }
  }
}
