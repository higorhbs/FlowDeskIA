{
  "name": "flowdesk",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @flowdesk/web dev",
    "dev:backend": "pnpm --filter @flowdesk/backend dev",
    "build": "turbo run build",
    "google:oauth-setup": "node scripts/google-oauth-setup.mjs",
    "prepare:hosting": "node scripts/prepare-hosting.mjs",
    "build:hosting": "pnpm run prepare:hosting && FIREBASE_STATIC=1 pnpm --filter @flowdesk/web build",
    "deploy:hosting": "pnpm run build:hosting && npx firebase-tools deploy --only hosting",
    "stripe:sync-prices": "node scripts/stripe-sync-prices.mjs",
    "setup:billing-env": "node scripts/setup-billing-env.mjs"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "react": "$react",
      "react-dom": "$react-dom",
      "firebase": "^11.6.0"
    }
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
