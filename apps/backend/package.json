{
  "name": "@flowdesk/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm run build:deps && pnpm run build:whatsapp && node --watch src/index.js",
    "dev:redis": "docker compose -f ../../docker-compose.yml up -d redis",
    "build": "pnpm run build:deps && pnpm run build:whatsapp && node --check src/index.js",
    "build:deps": "pnpm --filter @flowdesk/shared build && pnpm --filter @flowdesk/firebase build && pnpm --filter @flowdesk/whatsapp-client build",
    "build:whatsapp": "tsc -p tsconfig.whatsapp.json",
    "start": "node src/index.js"
  },
  "dependencies": {
    "@flowdesk/firebase": "workspace:*",
    "@flowdesk/shared": "workspace:*",
    "@flowdesk/whatsapp-client": "workspace:*",
    "@hono/node-server": "^1.19.14",
    "@hono/swagger-ui": "^0.6.1",
    "axios": "^1.7.7",
    "bullmq": "^5.14.0",
    "date-fns": "^3.6.0",
    "hono": "^4.12.23",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "typescript": "^5.5.0"
  }
}
