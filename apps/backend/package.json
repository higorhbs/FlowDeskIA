{
  "name": "@flowdesk/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node ../../scripts/backend-dev.mjs",
    "sync:docker": "node scripts/sync-docker-monorepo.mjs",
    "build": "pnpm run sync:docker && pnpm run build:docker",
    "build:docker": "pnpm run build:deps && pnpm run build:whatsapp && node --check src/index.js",
    "build:deps": "pnpm --filter @flowdesk/shared run build && pnpm --filter @flowdesk/firebase --filter @flowdesk/whatsapp-client --parallel run build",
    "build:whatsapp": "tsc -p tsconfig.whatsapp.json && node scripts/copy-whatsapp-js.mjs",
    "start": "node src/index.js"
  },
  "dependencies": {
    "@flowdesk/firebase": "workspace:*",
    "@flowdesk/shared": "workspace:*",
    "@flowdesk/whatsapp-client": "workspace:*",
    "@hono/node-server": "^1.19.14",
    "@hono/swagger-ui": "^0.6.1",
    "axios": "^1.7.7",
    "date-fns": "^3.6.0",
    "hono": "^4.12.23",
    "stripe": "^22.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "typescript": "^5.5.0"
  }
}
