{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false,
    "esModuleInterop": true
  },
  "include": ["api/**/*.js", "src/**/*.js", "src/**/*.ts"],
  "exclude": ["node_modules", "dist", "../web", "../../apps/web"]
}
