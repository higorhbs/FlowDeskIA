# URL base do backend do FlowDeskIA (sem barra no final)
FLOWDESK_API_BASE_URL=https://api.flowdeskia.com.br

# ID do negócio, visível na URL do painel (/businesses/<ID>/...)
FLOWDESK_BUSINESS_ID=

# Código de pareamento gerado no painel em Pedidos > Impressão automática > USB (agente local)
FLOWDESK_AGENT_TOKEN=

# Opcional: nome exato da impressora do sistema operacional a usar.
# Se não definido, o agente tenta detectar automaticamente (só funciona
# com segurança quando existe exatamente uma impressora instalada) e o
# nome escolhido deve ser confirmado/selecionado no painel.
FLOWDESK_PRINTER_NAME=
