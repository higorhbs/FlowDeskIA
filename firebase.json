{
  "hosting": {
    "public": "apps/web/out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "trailingSlash": true,
    "rewrites": [
      {
        "source": "/__/auth/**",
        "destination": "https://zapflow-higor-2026.firebaseapp.com/__/auth/**"
      },
      {
        "source": "/__/firebase/**",
        "destination": "https://zapflow-higor-2026.firebaseapp.com/__/firebase/**"
      },
      {
        "source": "/businesses/*/conversations",
        "destination": "/businesses/app/conversations/index.html"
      },
      {
        "source": "/businesses/*/conversations/**",
        "destination": "/businesses/app/conversations/index.html"
      },
      {
        "source": "/businesses/*/faqs",
        "destination": "/businesses/app/faqs/index.html"
      },
      {
        "source": "/businesses/*/faqs/**",
        "destination": "/businesses/app/faqs/index.html"
      },
      {
        "source": "/businesses/*/appointments",
        "destination": "/businesses/app/appointments/index.html"
      },
      {
        "source": "/businesses/*/appointments/**",
        "destination": "/businesses/app/appointments/index.html"
      },
      {
        "source": "/businesses/*/catalog",
        "destination": "/businesses/app/catalog/index.html"
      },
      {
        "source": "/businesses/*/catalog/**",
        "destination": "/businesses/app/catalog/index.html"
      },
      {
        "source": "/businesses/*/status",
        "destination": "/businesses/app/status/index.html"
      },
      {
        "source": "/businesses/*/status/**",
        "destination": "/businesses/app/status/index.html"
      },
      {
        "source": "/businesses/*/payments",
        "destination": "/businesses/app/payments/index.html"
      },
      {
        "source": "/businesses/*/payments/**",
        "destination": "/businesses/app/payments/index.html"
      },
      {
        "source": "/businesses/*/whatsapp",
        "destination": "/businesses/app/whatsapp/index.html"
      },
      {
        "source": "/businesses/*/whatsapp/**",
        "destination": "/businesses/app/whatsapp/index.html"
      },
      {
        "source": "/businesses/*/settings",
        "destination": "/businesses/app/settings/index.html"
      },
      {
        "source": "/businesses/*/settings/**",
        "destination": "/businesses/app/settings/index.html"
      }
    ]
  }
}
